{
  "name": "bm-jmx-recorder",
  "version": "0.1.0",
  "description": "MV3 Chrome extension that captures HTTP + Selenium interactions and exports JMX",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build --mode production && node scripts/copy-manifest.mjs",
    "lint": "eslint src && prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pack-crx": "node scripts/pack-crx.mjs",
    "postinstall": "playwright install chromium --with-deps"
  },
  "dependencies": {},
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.6.0",
    "@types/chrome": "^0.1.30",
    "@vitejs/plugin-react": "^4.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@playwright/test": "^1.44.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.0",
    "terser": "^5.39.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}