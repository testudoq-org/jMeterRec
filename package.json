{
  "name": "Capyultura",
  "version": "0.1.0",
  "description": "MV3 Chrome extension that captures HTTP traffic and exports JMX",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build --mode production && node scripts/copy-manifest.mjs",
    "lint": "eslint src && prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "dry": "dry4js src",
    "crap": "crap4js",
    "pack-crx": "node scripts/pack-crx.mjs",
    "postinstall": "playwright install chromium --with-deps"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.6.0",
    "@playwright/test": "^1.44.0",
    "@types/chrome": "^0.1.30",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "crap4js": "^1.0.1-beta.3",
    "dry-4-js": "^0.5.0-alpha.6",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.2.0",
    "terser": "^5.39.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@vitest/coverage-v8": "^4.1.8"
  }
}
