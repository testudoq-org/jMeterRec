{
  "manifest_version": 3,
  "name": "BM JMX Recorder",
  "version": "0.1.0",
  "description": "Record HTTP traffic and export JMeter JMX",
  "permissions": ["storage", "unlimitedStorage", "webRequest", "webRequestBlocking", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "BM JMX Recorder"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  }
}
