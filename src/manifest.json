{
  "manifest_version": 3,
  "name": "Capultura BETA",
  "version": "0.1.0",
  "description": "Capultura BETA - Record, script and scale real browser flows (JMX, Playwright) for reliable performance testing. THIS EXTENSION IS FOR BETA TESTING.",
  "homepage_url": "https://github.com/testudoq-org/jMeterRec",
  "minimum_chrome_version": "88",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "webRequest",
    "activeTab",
    "windows",
    "downloads",
    "scripting",
    "browsingData"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Capultura BETA",
    "default_icon": "icons/icon-128.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
