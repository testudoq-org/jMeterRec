{
  "manifest_version": 3,
  "name": "BM JMX Recorder",
  "version": "0.1.0",
  "description": "Record HTTP + Selenium interactions and export to JMeter JMX",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "webRequest", "webRequestBlocking", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BM JMX Recorder"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["icons/*"]
    }
  ]
}
